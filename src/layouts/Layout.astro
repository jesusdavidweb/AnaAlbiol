---
import "../styles/global.css";
import Header from "../components/Header.svelte";
import Footer from "../components/Footer.astro";
import { Font } from "astro:assets";

import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";

import CookieBanner from "../components/CookieBanner.svelte";

import ogImg from "../assets/images/WEB_AnaAlbiolJUN25-26.webp";

interface Props {
    title: string;
    description?: string;
    headerTheme?: "light" | "dark";
    preloadImage?: string;
}

const {
    title,
    description = "Web oficial de Ana Albiol. Desarrollo personal, coherencia y vida. Herramientas para dejar de posponer tu vida.",
    headerTheme = "light",
    preloadImage,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const basePath = import.meta.env.BASE_URL;
const basePathWithoutTrailingSlash =
    basePath.length > 1 && basePath.endsWith("/")
        ? basePath.slice(0, -1)
        : basePath;
const currentPath =
    basePathWithoutTrailingSlash !== "/" &&
    Astro.url.pathname.startsWith(basePathWithoutTrailingSlash)
        ? Astro.url.pathname.slice(basePathWithoutTrailingSlash.length) || "/"
        : Astro.url.pathname;
const withBasePath = (path: string) => {
    const normalizedPath = path.startsWith("/") ? path : `/${path}`;
    if (basePathWithoutTrailingSlash === "/") {
        return normalizedPath;
    }
    return `${basePathWithoutTrailingSlash}${normalizedPath}`;
};
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link rel="canonical" href={canonicalURL.href} />

        <!-- Demo: bloquear indexación en todos los buscadores -->
        <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, nocache" />
        <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex, nocache" />
        <meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet, noimageindex, nocache" />

        <!-- Astro Font Component for Google Fonts -->
        <Font cssVariable="--font-body" preload />
        <Font cssVariable="--font-subtitle" preload />
        <Font cssVariable="--font-heading" preload />

        <!-- Preload LCP hero image if provided -->
        {
            preloadImage && (
                <link
                    rel="preload"
                    as="image"
                    href={preloadImage}
                    type="image/webp"
                />
            )
        }

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta
            property="og:image"
            content={new URL(ogImg.src, Astro.site)}
        />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:site_name" content="Ana Albiol" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta
            name="twitter:image"
            content={new URL(ogImg.src, Astro.site)}
        />

        <!-- Security Headers -->
        <meta http-equiv="X-Content-Type-Options" content="nosniff" />
        <meta name="referrer" content="strict-origin-when-cross-origin" />

        <link
            rel="icon"
            type="image/svg+xml"
            href={withBasePath("/images/favicon-ana.svg")}
        />

        <!-- View Transitions -->
        <ClientRouter />

        <!-- Using local global.css imported in frontmatter -->
        <script is:inline>
            // Check session storage immediately to avoid preloader flash on navigation
            if (sessionStorage.getItem("ana_albiol_preloader_visited")) {
                document.documentElement.setAttribute(
                    "data-preloader-visited",
                    "true",
                );
            }
        </script>
        <script is:inline define:vars={{ basePath }}>
            const applyBasePathToInternalLinks = () => {
                if (basePath === "/") {
                    return;
                }

                const prefix =
                    basePath.length > 1 && basePath.endsWith("/")
                        ? basePath.slice(0, -1)
                        : basePath;

                document
                    .querySelectorAll('a[href^="/"], form[action^="/"]')
                    .forEach((element) => {
                        const attribute =
                            element.tagName === "FORM" ? "action" : "href";
                        const value = element.getAttribute(attribute);

                        if (
                            !value ||
                            value.startsWith("//") ||
                            value.startsWith(`${prefix}/`)
                        ) {
                            return;
                        }

                        element.setAttribute(attribute, `${prefix}${value}`);
                    });
            };

            document.addEventListener("DOMContentLoaded", () => {
                applyBasePathToInternalLinks();
            });

            document.addEventListener("astro:after-swap", () => {
                applyBasePathToInternalLinks();
            });
        </script>
    </head>
    <body>
        <Header
            client:load
            theme={headerTheme}
            currentPath={currentPath}
        />
        <main transition:animate={fade({ duration: "0.35s" })}>
            <slot />
        </main>
        <Footer />
        <CookieBanner client:load />

        <script>
            import { inView, animate } from "motion";

            // Global observer for `.fade-up` containers.
            // The CSS sets them to opacity:0, but the components/pages that
            // use this class only animate their *children* by ID — so the
            // parent wrapper itself would stay invisible without this script.
            function initFadeUpAnimations() {
                const elements = document.querySelectorAll(".fade-up");
                elements.forEach((el) => {
                    inView(el, () => {
                        animate(
                            el,
                            { opacity: [0, 1], y: [40, 0] },
                            { duration: 0.8, easing: "ease-out" },
                        );
                    });
                });
            }

            initFadeUpAnimations();
            document.addEventListener("astro:after-swap", initFadeUpAnimations);
        </script>
    </body>
</html>
